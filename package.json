{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -k -n renderer,main \"pnpm --filter renderer dev\" \"pnpm --filter main dev\"",
    "prepare": "fenge install",
    "style": "fenge",
    "style:update": "fenge -u",
    "test": "pnpm style && pnpm typecheck && pnpm -r test",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "10.0.3",
    "fenge": "0.14.5",
    "typescript": "6.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "10.33.0"
    }
  }
}
