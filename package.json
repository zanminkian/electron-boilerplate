{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "run-pty % pnpm --filter renderer dev % pnpm --filter main dev",
    "prepare": "fenge install",
    "style": "fenge",
    "style:update": "fenge -u",
    "test": "pnpm style && pnpm typecheck && pnpm -r test",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "fenge": "0.13.3",
    "run-pty": "6.0.2",
    "typescript": "6.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "10.33.0"
    }
  }
}
